				"updated": "20260426180032"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Выберите нужный блок заголовка во вкладке редактора, зажмите значок блока заголовка и перетащите его в панель документов. После преобразования блока заголовка в блок документа:"
				}
			]
		},
		{
			"ID": "20240415092450-22n7hw8",
			"Type": "NodeList",
			"ListData": {},
			"Properties": {
