			"Properties": {
				"id": "20210104091550-bqansnf",
				"updated": "20240415092701"
			},
			"Children": [
				{
					"ID": "20210104091550-x0apmia",
					"Type": "NodeListItem",
					"Data": "*",
					"ListData": {
						"BulletChar": 42,
						"Padding": 2,
						"Marker": "Kg==",
						"Num": -1
					},
					"Properties": {
						"id": "20210104091550-x0apmia"
					},
					"Children": [
						{
							"ID": "20210302223904-6mjxwze",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20210302223904-6mjxwze"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Исходное имя документа станет именем заголовка"
								}
							]
						}
					]
				},
				{
					"ID": "20210104091550-gheb1lp",
					"Type": "NodeListItem",
					"Data": "*",
					"ListData": {
						"Tight": true,
						"BulletChar": 42,
						"Padding": 2,
						"Marker": "Kg==",
						"Num": -1
					},
					"Properties": {
						"id": "20210104091550-gheb1lp",
						"updated": "20240415092701"
					},
					"Children": [
						{
							"ID": "20210302223904-f6nje4v",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20210302223904-f6nje4v",
								"updated": "20240415092701"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Логически блок документа — заголовок первого уровня, относительный уровень изменится в зависимости от места вставки"
								}
							]
						}
					]
				},
				{
					"ID": "20210104091550-ha3yjqb",
					"Type": "NodeListItem",
					"Data": "*",
					"ListData": {
						"Tight": true,
						"BulletChar": 42,
						"Padding": 2,
						"Marker": "Kg==",
						"Num": -1
					},
					"Properties": {
						"id": "20210104091550-ha3yjqb"
					},
					"Children": [
						{
							"ID": "20210302223904-tzxzgjp",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20210302223904-tzxzgjp"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Уровни заголовков исходного документа будут скорректированы в соответствии с местом вставки"
								}
							]
						},
						{
							"ID": "20210104091550-48lap6m",
							"Type": "NodeList",
							"ListData": {
								"Tight": true,
								"BulletChar": 42,
								"Padding": 2,
								"Marker": "Kg==",
								"Num": -1
							},
							"Properties": {
								"id": "20210104091550-48lap6m"
							},
							"Children": [
								{
									"ID": "20210104091550-gssmeiv",
									"Type": "NodeListItem",
									"Data": "*",
									"ListData": {
										"Tight": true,
										"BulletChar": 42,
										"Padding": 2,
										"Marker": "Kg==",
										"Num": -1
									},
									"Properties": {
										"id": "20210104091550-gssmeiv"
									},
									"Children": [
										{
											"ID": "20210302223904-pejga37",
											"Type": "NodeParagraph",
											"Properties": {
												"id": "20210302223904-pejga37"
											},
											"Children": [
												{
													"Type": "NodeText",
													"Data": "Для ситуации 1 выше: например, если исходный документ содержит заголовки первого, второго и третьего уровней, а место вставки — заголовок второго уровня, то заголовок, полученный из документа, станет заголовком второго уровня, а заголовки 1-3 уровней станут заголовками 2, 3 и 4 уровней"
												}
											]
										}
									]
								},
								{
									"ID": "20210104091550-kjszjvo",
									"Type": "NodeListItem",
									"Data": "*",
									"ListData": {
										"Tight": true,
										"BulletChar": 42,
										"Padding": 2,
										"Marker": "Kg==",
										"Num": -1
									},
									"Properties": {
										"id": "20210104091550-kjszjvo"
									},
									"Children": [
										{
											"ID": "20210302223904-cxnr58w",
											"Type": "NodeParagraph",
											"Properties": {
												"id": "20210302223904-cxnr58w"
											},
											"Children": [
												{
													"Type": "NodeText",
													"Data": "Для ситуации 2 выше: например, исходный документ содержит заголовки 1, 2 и 3 уровней, а место вставки — блок абзаца под заголовком второго уровня. Заголовок, полученный из документа, станет заголовком третьего уровня, а заголовки 1, 2 и 3 уровней станут заголовками 3, 4 и 5 уровней"
												}
											]
										}
									]
								}
							]
						}
					]
				}
			]
		},
