		{
			"ID": "20210104091546-qkjvm7e",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20210104091546-qkjvm7e",
				"updated": "20210428225413"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Граф связей делится на уровень документа и глобальный. Граф документа разворачивается от текущего блока документа и показывает все блоки контента, связанные с документом (прямые и обратные ссылки); глобальный граф — это все блоки и связи во всех блокнотах."
				}
			]
		},
		{
			"ID": "20210205173507-y14s7qj",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20210205173507-y14s7qj"
			}
		},
		{
			"ID": "20210428225309-7xmy8j5",
