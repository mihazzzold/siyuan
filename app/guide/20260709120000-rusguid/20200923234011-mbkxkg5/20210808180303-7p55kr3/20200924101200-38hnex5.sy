			"Properties": {
				"id": "20210428225309-7xmy8j5",
				"updated": "20250115164053"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Удерживая "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Ctrl"
				},
				{
					"Type": "NodeText",
					"Data": "​, щёлкните по узлу — произойдёт переход к узлу."
				}
			]
		},
