			"Children": [
				{
					"Type": "NodeText",
					"Data": "​"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "tag",
					"TextMarkTextContent": "Примечание"
				},
				{
					"Type": "NodeText",
					"Data": "​: поиск упоминаний ведётся только по обычному тексту — без строчных элементов вроде жирного и курсива и без блочных элементов вроде блоков кода и диаграмм. Правила те же, что и "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "block-ref",
					"TextMarkBlockRefID": "20211010212319-km7zoz6",
					"TextMarkBlockRefSubtype": "s",
					"TextMarkTextContent": "правила обнаружения виртуальных ссылок"
