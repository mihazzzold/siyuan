			"Children": [
				{
					"Type": "NodeText",
					"Data": "После ввода "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "(("
				},
				{
					"Type": "NodeText",
					"Data": " запускается поиск ссылки на блок контента. Продолжайте вводить текст — он станет ключевым словом поиска. В результатах поиска выберите нужное стрелками вверх/вниз и нажмите Enter, чтобы завершить ссылку на блок контента. После создания ссылки наведите мышь на якорный текст — появится слой предпросмотра с целевым блоком контента (блоком-определением). "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "tag",
					"TextMarkTextContent": "Блок контента/Ссылка"
				}
			]
		},
