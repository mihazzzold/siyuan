		"id": "20220628204454-l45no4x",
		"title": "Оптимизация типографики",
		"type": "doc",
		"updated": "20260613191858"
	},
	"Children": [
		{
			"ID": "20220628215200-vbu3gp5",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20220628215200-vbu3gp5",
				"updated": "20220628215200"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Обзор"
				}
			]
		},
		{
			"ID": "20220628215200-rylx88y",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220628215200-rylx88y",
				"updated": "20220628215227"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Стремясь записать содержимое быстро, мы часто пренебрегаем типографскими деталями: например, нет пробелов до и после строчного кода или жирного текста, нет пробелов между китайским и западным текстом."
				}
			]
		},
		{
			"ID": "20220628215200-g80ucpm",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220628215200-g80ucpm",
				"updated": "20220628215255"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Из-за этого вёрстка содержимого выглядит менее аккуратно, и при последующем чтении возникают визуальные помехи. Конечно, это лишь наше ощущение — возможно, это не проблема, а плотная вёрстка даже была нужна изначально."
				}
			]
		},
		{
			"ID": "20220628215200-nsc2ul9",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20220628215200-nsc2ul9",
				"updated": "20260613191858"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Как использовать"
				}
			]
		},
		{
			"ID": "20220628215200-tx6je1b",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220628215200-tx6je1b",
				"updated": "20250115151312"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Выберите "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Оптимизировать типографику"
				},
				{
					"Type": "NodeText",
					"Data": "​ в меню "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "︙"
				},
				{
					"Type": "NodeText",
					"Data": "​ в правом верхнем углу редактора. После обработки пробел будет автоматически вставлен до и после следующих элементов документа:"
				}
			]
		},
