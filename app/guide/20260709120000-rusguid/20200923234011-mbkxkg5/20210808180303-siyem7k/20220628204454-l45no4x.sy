			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Автоматическое резервное копирование"
				}
			]
		},
		{
			"ID": "20220628215200-cbx0u64",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220628215200-cbx0u64",
				"updated": "20220628215421"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Перед фактическим выполнением оптимизации типографики SiYuan автоматически сделает резервную копию исходного документа, поэтому, если результат оптимизации не устроит, его можно откатить через "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "block-ref",
					"TextMarkBlockRefID": "20210615213222-z4j45ib",
					"TextMarkBlockRefSubtype": "s",
