			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614194307-5jddutf",
				"updated": "20260614194307"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Когда блок контента становится флеш-карточкой, система автоматически планирует повторения по алгоритму интервального повторения FSRS (репозиторий GitHub: open-spaced-repetition/free-spaced-repetition-scheduler), напоминая о повторении в момент забывания и помогая превращать краткосрочную память в долгосрочную."
				}
			]
		},
		{
			"ID": "20260614194307-zxjk4q6",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20260614194307-zxjk4q6",
				"updated": "20260614194412"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Использование"
				}
			]
		},
		{
			"ID": "20260614194307-fa76g19",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614194307-fa76g19",
				"updated": "20260614194412"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Создание флеш-карточек"
				}
			]
		},
