			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "SiYuan поставляется со встроенным CLI (интерфейсом командной строки), который обращается к данным рабочего пространства напрямую, без запуска сервера ядра. Он хорошо подходит для скриптов, пакетного управления и операций чтения/записи заметок совместно с ИИ-агентами."
				}
			]
		},
		{
			"ID": "20260618124055-tz856aj",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260618124055-tz856aj",
				"updated": "20260618124055"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "​"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "siyuan [global flags] &lt;command&gt; [arguments]"
				},
				{
					"Type": "NodeText",
					"Data": "​"
				}
			]
		},
