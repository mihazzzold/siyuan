							"Type": "NodeParagraph",
							"Properties": {
								"id": "20260614112546-s92qcjx",
								"updated": "20260614112546"
							},
							"Children": [
								{
									"Type": "NodeTextMark",
									"TextMarkType": "strong",
									"TextMarkTextContent": "Прямоугольная область"
								},
								{
									"Type": "NodeText",
									"Data": ": нажмите кнопку аннотирования области на панели PDF, затем растяните прямоугольник на странице PDF. Поддерживаются два стиля: залитый прямоугольник (с фоновым цветом) и прямоугольник-рамка (только границы); переключаются кнопкой стиля в меню аннотации"
								}
							]
						}
					]
				}
			]
		},
		{
