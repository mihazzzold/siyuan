		{
			"ID": "20260613155453-gpdea21",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260613155453-gpdea21",
				"updated": "20260613155453"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Уникальный идентификатор каждой записи базы данных. В записях типа «блок контента» первичный ключ привязан к соответствующему блоку контента, соединяя структурированные данные с неструктурированным содержимым. В каждой таблице должно быть ровно одно поле первичного ключа."
				}
			]
		},
