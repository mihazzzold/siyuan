						}
					]
				}
			]
		},
		{
			"ID": "20220511185726-afhx2x0",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220511185726-afhx2x0",
				"updated": "20220511185726"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "​"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "tag",
					"TextMarkTextContent": "Примечание"
				},
				{
					"Type": "NodeText",
					"Data": "​: будьте внимательны перед использованием, чтобы существующие данные не были перезаписаны безвозвратно."
				}
			]
		},
		{
			"ID": "20260614201131-o3j7npn",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20260614201131-o3j7npn",
				"updated": "20260614201131"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": ".sy.zip"
				}
			]
		},
		{
			"ID": "20260614201131-vkz4lsh",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260614201131-vkz4lsh",
				"updated": "20260614201131"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": ".sy.zip — родной формат документов SiYuan для импорта отдельных документов, экспортированных из других рабочих пространств SiYuan. Файлы .sy.zip можно просто перетащить в дерево документов, чтобы завершить импорт. Импортированный документ включает полное содержимое, дочерние документы, файлы ресурсов и атрибуты блоков."
				}
			]
		},
		{
			"ID": "20220317223639-nm0nbos",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20220317223639-nm0nbos",
				"updated": "20250115151427"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Экспорт"
				}
			]
		},
		{
			"ID": "20220317223639-q9wpt0n",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20220317223639-q9wpt0n",
				"updated": "20250115151427"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Копирование редактируемого содержимого"
				}
			]
		},
		{
			"ID": "20220317223639-0cejyci",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220317223639-0cejyci",
				"updated": "20250115151031"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Выделив содержимое, используйте сочетание копирования "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Ctrl"
				},
				{
					"Type": "NodeText",
					"Data": "​+"
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "C"
				},
				{
					"Type": "NodeText",
					"Data": "​ — в буфере обмена будет стандартный Markdown-текст."
				}
			]
		},
		{
			"ID": "20220317223639-gh06ppf",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220317223639-gh06ppf",
				"updated": "20250115151427"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Если нужно скопировать HTML-содержимое, перед копированием переключитесь на "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Предпросмотр экспорта"
				},
				{
					"Type": "NodeText",
					"Data": "​ через "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Переключение режима"
				},
				{
					"Type": "NodeText",
					"Data": "​ в меню "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "︙"
				},
				{
					"Type": "NodeText",
					"Data": "​ в правом верхнем углу вкладки редактора."
				}
			]
		},
		{
			"ID": "20220317223639-yw04r9h",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
