		"title": "Импорт и экспорт",
		"type": "doc",
		"updated": "20220317224017"
	},
	"Children": [
		{
			"ID": "20220317223639-mfrorjw",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20220317223639-mfrorjw",
				"updated": "20220317223642"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Импорт"
				}
			]
		},
		{
			"ID": "20220511185728-vimzxxi",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20220511185728-vimzxxi",
				"updated": "20220511185730"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Markdown"
				}
			]
		},
		{
			"ID": "20220317223639-erkjm5e",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220317223639-erkjm5e",
				"updated": "20220511190015"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "SiYuan поддерживает импорт Markdown-файлов. Поэтому, если нужно импортировать данные из другой программы для заметок, сначала преобразуйте их в Markdown-файлы."
				}
			]
		},
		{
			"ID": "20220317223639-413lq4c",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220317223639-413lq4c",
				"updated": "20220317223836"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Если при импорте встречается синтаксис изображения (локальный относительный путь) вида "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "![foo](images/bar.png)"
				},
				{
					"Type": "NodeText",
					"Data": "​, SiYuan преобразует "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "images/bar.png"
				},
				{
					"Type": "NodeText",
					"Data": "​ в "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "block-ref",
					"TextMarkBlockRefID": "20200924100744-dsuftlg",
					"TextMarkBlockRefSubtype": "s",
					"TextMarkTextContent": "assets"
				},
				{
					"Type": "NodeText",
					"Data": ". Но если это "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": ".images/bar.png"
				},
				{
					"Type": "NodeText",
					"Data": "​, преобразования не будет, потому что пути, начинающиеся с "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "."
				},
				{
					"Type": "NodeText",
					"Data": "​, — скрытые файлы, и SiYuan их не обрабатывает."
				}
			]
		},
		{
			"ID": "20240426184519-2sz9vdh",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20240426184519-2sz9vdh",
				"updated": "20240426184519"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Если нужно распознавать расширенный синтаксис (например, верхний индекс "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "^foo^"
				},
				{
					"Type": "NodeText",
					"Data": "​, нижний индекс "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "~foo~"
				},
				{
					"Type": "NodeText",
					"Data": "​, теги "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "#foo"
				},
				{
					"Type": "NodeText",
					"Data": "​ и формулы "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "$foo$"
				},
				{
					"Type": "NodeText",
					"Data": "​ и т. д.), включите соответствующие переключатели в "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Настройки"
				},
				{
					"Type": "NodeText",
					"Data": "​ - "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Редактор"
				},
				{
					"Type": "NodeText",
					"Data": "​ - "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Синтаксис Markdown"
				},
				{
					"Type": "NodeText",
					"Data": "​."
				}
			]
		},
		{
			"ID": "20220511185726-ntfstug",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20220511185726-ntfstug",
				"updated": "20260614201131"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Данные"
				}
			]
		},
		{
			"ID": "20220511185726-bno5gvn",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220511185726-bno5gvn",
				"updated": "20220511185757"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Импортировать и экспортировать данные можно в "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Настройки"
				},
				{
					"Type": "NodeText",
					"Data": " - "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Приложение"
				},
				{
					"Type": "NodeText",
					"Data": " на настольной версии и в "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Приложение"
				},
				{
					"Type": "NodeText",
					"Data": " в правой панели на мобильной. Экспорт здесь полностью копирует и упаковывает папку "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "workspace/data/"
				},
				{
					"Type": "NodeText",
					"Data": " в zip-архив."
				}
			]
		},
		{
			"ID": "20220511185726-621fxrc",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220511185726-621fxrc",
				"updated": "20220511185841"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Функция "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "Импорт данных"
				},
				{
					"Type": "NodeText",
					"Data": " обрабатывает только архив данных, экспортированный на шагах выше. Импорт копируется в текущую папку "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "workspace/data/"
				},
				{
					"Type": "NodeText",
					"Data": " согласно путям файлов в архиве:"
				}
			]
		},
