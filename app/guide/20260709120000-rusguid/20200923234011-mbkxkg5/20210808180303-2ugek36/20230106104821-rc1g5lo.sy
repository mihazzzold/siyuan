			]
		},
		{
			"ID": "20230106105213-fv73pzh",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230106105213-fv73pzh",
				"updated": "20230106105213"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Рабочее пространство используется для хранения данных, истории, конфигурации и файлов, нужных во время работы."
				}
			]
		},
		{
			"ID": "20230106105213-onvk511",
