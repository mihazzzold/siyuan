			"Children": [
				{
					"ID": "20230106105213-kksj7c9",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
					},
					"Properties": {
						"id": "20230106105213-kksj7c9",
						"updated": "20230106105213"
					},
					"Children": [
						{
							"ID": "20230106105213-7rylcc5",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20230106105213-7rylcc5",
								"updated": "20230106105213"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Разные рабочие пространства изолированы друг от друга папками файловой системы"
								}
							]
						}
					]
				},
				{
					"ID": "20230106105213-u8pqybt",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
					},
					"Properties": {
						"id": "20230106105213-u8pqybt",
						"updated": "20230106105213"
					},
					"Children": [
						{
							"ID": "20230106105213-afvg9pr",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20230106105213-afvg9pr",
								"updated": "20230106105213"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Рабочее пространство может обслуживаться только одним процессом ядра"
								}
							]
						}
					]
				}
			]
		},
		{
			"ID": "20230109113955-x1euosn",
