			"Type": "NodeParagraph",
			"Properties": {
				"id": "20211010212319-vmn01s2",
				"updated": "20211010212551"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Виртуальная ссылка — это разновидность «ссылки на блок», которая определяется автоматически на основе текста якоря существующих ссылок на блоки или имени блока; она не связывается с блоком по-настоящему, а лишь помечается в редакторе и поддерживает предпросмотр во всплывающем окне."
				}
			]
		},
		{
			"ID": "20211010212319-8c501rm",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20211010212319-8c501rm",
				"updated": "20211010212319"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Как использовать"
				}
			]
		},
