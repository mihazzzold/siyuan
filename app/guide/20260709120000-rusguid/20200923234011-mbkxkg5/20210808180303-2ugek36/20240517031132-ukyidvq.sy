							"Children": [
								{
									"Type": "NodeText",
									"Data": "Включите переключатель "
								},
								{
									"Type": "NodeTextMark",
									"TextMarkType": "kbd",
									"TextMarkTextContent": "Базовая аутентификация сервиса"
								},
								{
									"Type": "NodeText",
