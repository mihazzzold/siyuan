									"TextMarkType": "code",
									"TextMarkTextContent": "le"
								},
								{
									"Type": "NodeText",
									"Data": "​), третий — пороговое значение. Например: "
								},
								{
									"Type": "NodeTextMark",
									"TextMarkType": "code",
