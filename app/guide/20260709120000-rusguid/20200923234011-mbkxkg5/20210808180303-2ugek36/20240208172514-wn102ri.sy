								"updated": "20260613162855"
							},
							"Children": [
								{
									"Type": "NodeTextMark",
									"TextMarkType": "strong",
									"TextMarkTextContent": "Управление столбцами"
								},
								{
									"Type": "NodeText",
									"Data": ": каждый столбец — это поле. Перетаскивайте, чтобы менять ширину и порядок столбцов. Щёлкните заголовок столбца правой кнопкой, чтобы изменить, удалить или скрыть поле"
								}
							]
						}
					]
				},
				{
					"ID": "20260613162855-crbc3t8",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
					},
					"Properties": {
						"id": "20260613162855-crbc3t8",
						"updated": "20260613162855"
					},
					"Children": [
						{
							"ID": "20260613162855-mlvtokg",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20260613162855-mlvtokg",
								"updated": "20260613162855"
							},
							"Children": [
								{
									"Type": "NodeTextMark",
									"TextMarkType": "strong",
									"TextMarkTextContent": "Операции со строками"
								},
								{
									"Type": "NodeText",
									"Data": ": щёлкните начало строки, чтобы раскрыть её детали. Перетаскивайте строки для изменения порядка. Щёлкните строку правой кнопкой, чтобы удалить, дублировать или переместить в другую базу данных"
								}
							]
						}
					]
				},
