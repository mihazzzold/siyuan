							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Не используйте внешние адреса облачных ресурсов напрямую на других платформах: адрес нестабилен, и смена доменного имени может повлиять на доступность"
								}
							]
						}
					]
				},
				{
					"ID": "20211127232925-5kng5c4",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
