		{
			"ID": "20220407085720-fplg9ha",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220407085720-fplg9ha",
				"updated": "20230621111510"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Если нужно удалить файлы из облачного хостинга ресурсов, перейдите в "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "a",
					"TextMarkAHref": "https://liuyun.io/settings/file?type=3",
					"TextMarkTextContent": "LiuYun - Настройки - Файлы - Заметка"
				},
				{
					"Type": "NodeText",
					"Data": ". После удаления занятое файлом место в облачном хранилище освобождается сразу, но очистка кэша CDN может сработать не мгновенно: URL файла останется доступным, пока кэш CDN не истечёт автоматически через 30 дней."
				}
			]
		},
		{
