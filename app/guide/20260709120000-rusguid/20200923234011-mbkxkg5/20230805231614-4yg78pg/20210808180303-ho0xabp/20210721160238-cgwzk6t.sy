					"Children": [
						{
							"ID": "20211127232925-orvgt70",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20211127232925-orvgt70",
								"updated": "20211127233055"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Не загружайте незаконные или чувствительные файлы. Загруженные файлы проверяются сторонними сервисами (порнография, терроризм, чувствительные персоны и т. д.). Если обнаружится загрузка незаконных файлов, аккаунт пользователя будет навсегда заблокирован с соответствующей юридической ответственностью"
								}
							]
						}
					]
				}
			]
