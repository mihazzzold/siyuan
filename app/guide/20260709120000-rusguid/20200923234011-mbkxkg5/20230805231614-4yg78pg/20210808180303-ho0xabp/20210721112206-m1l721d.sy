					"Children": [
						{
							"ID": "20220510105000-b5t73zs",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20220510105000-b5t73zs",
								"updated": "20220510105000"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Через 30 секунд после изменения данных, если изменений больше нет, выполняется сравнение; если изменения продолжаются, ожидание продлевается ещё на 30 секунд"
								}
							]
						}
					]
				},
				{
					"ID": "20220510105000-zwj8s5g",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
					},
					"Properties": {
						"id": "20220510105000-zwj8s5g",
