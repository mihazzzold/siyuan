							"Type": "NodeParagraph",
							"Properties": {
								"id": "20220510105000-qtt8m12",
								"updated": "20220510105000"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Если данных не меняются, интервал растёт: 5 минут, 8 минут, 16 минут, 32 минуты..."
								}
							]
						}
					]
				}
			]
		},
		{
