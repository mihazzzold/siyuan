			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Синхронизация данных — это поддержание согласованности данных папки "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "workspace/data/"
				},
				{
					"Type": "NodeText",
					"Data": "​ на нескольких устройствах; она включает ресурсы, пользовательские значки, плагины, сниппеты кода, шаблоны, виджеты и данные документов."
				}
			]
		},
		{
			"ID": "20210721112403-36ckg1c",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
