			"Children": [
				{
					"Type": "NodeText",
					"Data": "Алгоритм интервалов автоматической синхронизации описывается так:"
				}
			]
		},
		{
			"ID": "20220510105000-ch4eba9",
			"Type": "NodeList",
			"ListData": {},
			"Properties": {
