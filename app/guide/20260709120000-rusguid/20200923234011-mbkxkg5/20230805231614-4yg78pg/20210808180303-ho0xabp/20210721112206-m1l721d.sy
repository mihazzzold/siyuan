		{
			"ID": "20220307095105-ch6menj",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220307095105-ch6menj",
				"updated": "20220307095118"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Из принципа работы выше следует, что SiYuan поддерживает только поочерёдную синхронизацию данных на нескольких устройствах: после завершения синхронизации на устройстве A выполняется синхронизация на устройстве B. Одновременная синхронизация нескольких устройств не поддерживается — она приведёт к неожиданной перезаписи данных."
				}
			]
		},
		{
			"ID": "20220307095105-sjw6ap6",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
