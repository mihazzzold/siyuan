				"updated": "20250115162705"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Как использовать"
				}
			]
		},
		{
			"ID": "20220703231817-1vexlxp",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220703231817-1vexlxp",
				"updated": "20220821170709"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "После "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "block-ref",
					"TextMarkBlockRefID": "20220615120602-niddqzo",
					"TextMarkBlockRefSubtype": "s",
					"TextMarkTextContent": "инициализации ключа репозитория данных"
				},
				{
					"Type": "NodeText",
					"Data": ", если всё прошло успешно, синхронизация уже настроена. Если вы не знакомы с настройкой синхронизации, рекомендуется открыть мастер настройки, нажав кнопку синхронизации — через мастер настраивать проще."
				}
			]
		},
