		{
			"ID": "20230429115912-l9kkris",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115912-l9kkris",
				"updated": "20250115163213"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Переключатели WYSIWYG и предпросмотра экспорта находятся в меню "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "kbd",
					"TextMarkTextContent": "︙"
				},
				{
					"Type": "NodeText",
					"Data": "​ в правом верхнем углу редактора; переключатели редактирования WYSIWYG и режима «только чтение» — в правом верхнем углу верхней панели."
				}
			]
		},
		{
			"ID": "20260614111229-qohvu9t",
