			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "В SiYuan палитра команд вызывается через "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "code",
					"TextMarkTextContent": "Ctrl+Shift+P"
				},
				{
					"Type": "NodeText",
					"Data": "​ и позволяет быстро выполнять операции — открывать панели, переключать функции, переходить по документам — не блуждая по меню."
				}
