					"Data": "Обзор"
				}
			]
		},
		{
			"ID": "20230429115740-9ex50jz",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115740-9ex50jz",
				"updated": "20230429120220"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "В SiYuan встречается довольно сложная терминология, которая может сбивать с толку. В этой главе мы поясним термины по порядку — надеемся, это поможет лучше понять и использовать SiYuan."
				}
			]
		},
		{
			"ID": "20230429115740-vwvbugz",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20230429115740-vwvbugz",
				"updated": "20230429120317"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Обратите "
				},
				{
					"Type": "NodeTextMark",
					"TextMarkType": "tag",
					"TextMarkTextContent": "внимание"
				},
				{
					"Type": "NodeText",
					"Data": "​: там, где речь идёт о конкретных функциях, изложение ориентировано в основном на настольную версию."
				}
			]
		},
		{
			"ID": "20230429115740-co6bkzu",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20230429115740-co6bkzu",
