							"Type": "NodeParagraph",
							"Properties": {
								"id": "20230405172238-w6g62gw",
								"updated": "20230405172238"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Количество динамически загружаемых блоков: число загруженных блоков влияет в основном на редактор, особенно при большом количестве блоков формул, кода и диаграмм. Чем больше блоков загружено, тем вероятнее подвисания"
								}
							]
						}
					]
				},
				{
					"ID": "20230405172238-audj7tu",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
