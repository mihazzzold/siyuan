							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Порог мониторинга производительности задаётся переменной окружения "
								},
								{
									"Type": "NodeTextMark",
									"TextMarkType": "code",
									"TextMarkTextContent": "SIYUAN_PERFORMANCE_TIMING"
								},
								{
									"Type": "NodeText",
									"Data": "​ в миллисекундах, по умолчанию 15000, то есть 15 секунд"
