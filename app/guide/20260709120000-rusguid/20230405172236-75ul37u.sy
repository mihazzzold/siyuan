						{
							"ID": "20230405172238-r8tf112",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20230405172238-r8tf112",
								"updated": "20260426180046"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Количество блоков контента: число блоков сильно влияет на производительность — например, на раскрытие панели документов, поиск и запись данных. Но не переживайте: обычно даже миллионы блоков не оказывают большого влияния, если только каждый блок не слишком велик"
								}
							]
						}
					]
				},
				{
					"ID": "20230405172238-fd4cgjj",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
					},
					"Properties": {
						"id": "20230405172238-fd4cgjj",
