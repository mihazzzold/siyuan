								"updated": "20230405172238"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Складывайте редко используемые или вырезанные из веба документы отдельно в "
								},
								{
									"Type": "NodeTextMark",
									"TextMarkType": "code",
									"TextMarkTextContent": "Archive Notebook"
								},
								{
									"Type": "NodeText",
									"Data": "​ или "
								},
								{
									"Type": "NodeTextMark",
									"TextMarkType": "code",
									"TextMarkTextContent": "Clipped Notebook"
								},
								{
									"Type": "NodeText",
									"Data": "​; после его закрытия количество индексов базы данных уменьшится, что повысит производительность"
								}
							]
						}
					]
				},
