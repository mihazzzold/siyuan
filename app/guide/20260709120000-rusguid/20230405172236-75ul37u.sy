							"Properties": {
								"id": "20230405172238-8yofqlj",
								"updated": "20230405172238"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Номера строк в блоках кода: номера строк влияют в основном на редактор. Если в блоке кода много содержимого и включено отображение номеров строк, редактор может подвисать"
								}
							]
						}
					]
				},
