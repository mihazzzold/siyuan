								"updated": "20230405172439"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "Уменьшите "
								},
								{
									"Type": "NodeTextMark",
									"TextMarkType": "kbd",
									"TextMarkTextContent": "Количество отображаемых результатов поиска"
								},
								{
									"Type": "NodeText",
									"Data": "​; мы отслеживаем время ответа поисковых запросов, и если оно превышает порог, всплывающее окно предложит пользователю уменьшить этот параметр"
								}
							]
						},
						{
							"ID": "20230405172238-hd7d7wk",
