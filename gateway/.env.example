# Параметры продакшн-стека SiYuan Gateway (скопируйте в .env и заполните).
# install.sh генерирует этот файл автоматически.

# Порт шлюза наружу
GATEWAY_PORT=6810
# Часовой пояс
TZ=Europe/Moscow

# Код приглашения для регистрации (пусто = открытая регистрация)
GATEWAY_INVITE_CODE=
# true, если перед шлюзом стоит HTTPS-прокси (обязательно для внешнего доступа)
GATEWAY_SECURE_COOKIE=true

# Учётные данные MinIO (S3-хранилище). Смените на свои!
MINIO_ROOT_USER=siyuan
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
# Порт веб-консоли MinIO
MINIO_CONSOLE_PORT=9001

# Секрет для вывода ключей шифрования репозиториев пользователей.
# ОБЯЗАТЕЛЬНО случайный и сохранённый: при его потере зашифрованные S3-данные не восстановить.
GATEWAY_S3_KEY_SECRET=CHANGE_ME_random_secret
